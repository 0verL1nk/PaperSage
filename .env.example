# =========================
# Core LLM (app runtime)
# =========================
OPENAI_COMPATIBLE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AGENT_TEMPERATURE=0.1
AGENT_ENABLE_THINKING=false
AGENT_REASONING_EFFORT=

# Optional: live integration tests
RUN_LIVE_E2E=0
RUN_LIVE_REAL_PAPERS_E2E=0
RUN_REAL_SCENARIO_E2E=0
OPENAI_BASE_URL=
OPENAI_MODEL_NAME=
OPENAI_API_KEY=

# =========================
# OpenViking adapter runtime
# =========================
VIKING_BASE_URL=http://localhost:8080
VIKING_TIMEOUT_SECONDS=3.0
VIKING_MAX_RETRIES=2
VIKING_RETRY_BACKOFF_SECONDS=0.2

# =========================
# Policy Router Small Model (optional)
# If not set, router falls back to main model
# =========================
AGENT_POLICY_ROUTER_MODEL_NAME=
AGENT_POLICY_ROUTER_BASE_URL=
AGENT_POLICY_ROUTER_API_KEY=
AGENT_POLICY_ROUTER_TEMPERATURE=0.0

# Async policy interception
AGENT_POLICY_ASYNC_ENABLED=true
AGENT_POLICY_ASYNC_REFRESH_SECONDS=4.0
AGENT_POLICY_ASYNC_MIN_CONFIDENCE=0.6
AGENT_POLICY_ASYNC_MAX_STALENESS_SECONDS=20.0

# =========================
# RAG / memory pressure controls
# =========================
LOCAL_RAG_HYBRID_ENABLED=true
LOCAL_RAG_TOP_K=8
LOCAL_RAG_RERANK_ENABLED=false

# Project-level limits:
# - set to 0 for unlimited
# - set to positive values for bounded memory usage
LOCAL_RAG_PROJECT_MAX_CHARS=300000
LOCAL_RAG_PROJECT_MAX_CHUNKS=1200

# Embedding index batch size (lower => lower peak memory, slower build)
RAG_INDEX_BATCH_SIZE=256

# Session document text cache limit (chars)
AGENT_DOCUMENT_TEXT_CACHE_MAX_CHARS=1200000

# Vector store backend:
# - auto: prefer persistent Chroma, fallback to in-memory when unavailable
# - chroma: force persistent Chroma
# - inmemory: disable persistence, keep old behavior
AGENT_VECTORSTORE_BACKEND=auto
AGENT_VECTORSTORE_PERSIST_DIR=./.cache/vector_db

# =========================
# Tooling / web search (optional)
# =========================
BRAVE_SEARCH_API_KEY=
AGENT_SEARXNG_BASE_URLS=
AGENT_WEB_ENABLE_DDG_FALLBACK=0

# Workspace tool paths (optional)
AGENT_FILE_TOOLS_ROOT=
AGENT_TODO_FILE=.agent/todo.json
MINDMAP_CLI_PATH=

# Tool schema exposure level for runtime tracing/context accounting:
# - manifest: tool name + description only (default, recommended)
# - compact: include lightweight field/required summary
# - full: include full JSON schema
AGENT_TOOL_SCHEMA_LEVEL=manifest

# Redis queue (optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# MinerU parser (used by docker-compose)
MINERU_IMAGE=mineru:latest
MINERU_MODEL_SOURCE=local
MINERU_PARSE_BACKEND=pipeline
MINERU_PARSE_METHOD=auto
MINERU_TIMEOUT_SECONDS=180
MINERU_LANG_LIST=
